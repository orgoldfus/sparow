{
  "name": "sparow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "node ./scripts/run-with-node-version.mjs vitest run",
    "test:watch": "node ./scripts/run-with-node-version.mjs vitest",
    "typecheck": "tsc -b",
    "ui:harness": "node ./scripts/run-with-node-version.mjs vite --host 127.0.0.1 --port 4174",
    "smoke:foundation": "node ./scripts/run-with-node-version.mjs node ./scripts/smoke-foundation.mjs",
    "smoke:results-browser": "node ./scripts/run-with-node-version.mjs node ./scripts/smoke-results-browser.mjs",
    "smoke:shell-browser": "node ./scripts/run-with-node-version.mjs node ./scripts/smoke-shell-browser.mjs",
    "smoke:postgres": "node ./scripts/run-with-node-version.mjs node ./scripts/smoke-postgres.mjs",
    "verify": "node ./scripts/run-with-node-version.mjs node ./scripts/verify.mjs",
    "tauri": "node ./scripts/run-with-node-version.mjs tauri"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tauri-apps/api": "2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "0.577.0",
    "monaco-editor": "0.55.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@tailwindcss/vite": "4.2.1",
    "@tauri-apps/cli": "2.10.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.10.1",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "9.39.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "happy-dom": "20.8.3",
    "playwright": "^1.56.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.3",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}
